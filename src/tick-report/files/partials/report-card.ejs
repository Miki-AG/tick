<div class="card">
  <% if (mode === "landing") { %>
    <div class="projects-panel">
      <div class="projects-panel-title">Attached Projects</div>
      <div class="projects-empty" id="projects-empty" style="display:none;">No attached projects.</div>
      <div class="projects-wrap">
        <table class="projects-table">
          <thead>
            <tr>
              <th>project</th>
              <th>path</th>
              <th>status</th>
              <th>actions</th>
            </tr>
          </thead>
          <tbody id="project-rows"></tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="status-line" id="tick-status">loading...</div>

  <% if (mode === "project") { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>id</th>
            <th>title</th>
            <th>status</th>
            <th>priority</th>
            <th>owner</th>
            <th>labels</th>
            <th>updated</th>
            <th>updates</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </div>
  <% } %>
</div>
